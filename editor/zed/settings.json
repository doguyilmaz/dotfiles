{
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "base_keymap": "VSCode",
  "theme": "Atelier Cave Dark",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "ui_font_size": 16,
  "ui_font_family": "Fira Code",
  "buffer_font_size": 16,
  "edit_predictions": {
    "disabled_globs": [".env"]
  },
  "format_on_save": "on",
  "show_edit_predictions": true,
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": true
  },
  "tabs": {
    "close_position": "right",
    "git_status": true
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true
  },
  "languages": {
    "TypeScript": {
      "code_actions_on_format": {
        "source.organizeImports": false
      }
    },
    "TSX": {
      "code_actions_on_format": {
        "source.organizeImports": false
      }
    }
  },
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 2,
    "coloring": "indent_aware",
    "background_coloring": "disabled"
  },
  "tab_size": 2,
  "project_panel": {
    "button": true,
    "dock": "left",
    "git_status": true
  }
}
