# SSH Config Template
# Copy to ~/.ssh/config and fill in your values.
# Keys are machine-specific — generate per machine, don't sync.

Host github.com
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519

Host gitlab.com
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/gitlab_key

# Add custom hosts below:
# Host my-server
#   HostName 0.0.0.0
#   User ubuntu
#   IdentityFile ~/.ssh/my-key.key
